{
  "name": "pushssh",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync:site": "node scripts/sync-site-assets.mjs",
    "predev": "npm run sync:site",
    "dev": "astro dev --host 0.0.0.0 --port 3000",
    "prebuild": "npm run sync:site",
    "build": "astro build",
    "prepreview": "npm run sync:site",
    "preview": "astro preview --host 0.0.0.0 --port 3000",
    "clean": "node -e \"import('node:fs/promises').then((fs) => fs.rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "astro": "^5.14.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@rollup/rollup-linux-x64-musl": "4.60.1"
  }
}
