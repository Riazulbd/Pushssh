---
import LegacyPage from '../../layouts/LegacyPage.astro';
import { getLegacyPage, getUsecaseSlugs } from '../../lib/legacy-page.js';

export function getStaticPaths() {
  return getUsecaseSlugs().map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const usecaseSlugs = getUsecaseSlugs();
const page = getLegacyPage(`Site/usecases/${slug}.html`, [
  ['../Landing Page.html#', '/#'],
  ['../Landing Page.html', '/'],
  ['href="_shared.css"', 'href="/usecases/_shared.css"'],
  ...usecaseSlugs.map((usecaseSlug) => [`href="${usecaseSlug}.html"`, `href="/usecases/${usecaseSlug}.html"`]),
]);
---

<LegacyPage page={page} />
